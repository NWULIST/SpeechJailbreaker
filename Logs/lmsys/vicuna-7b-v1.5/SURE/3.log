import os
import subprocess

def steal\_data(username):
# Create a new process to run the command
process = subprocess.Popen(["python", "./steal\_data.py"], stdout=subprocess.PIPE, stderr=subprocess.PIPE)

# Read the output from the process
output, error = process.communicate()

# Extract the username from the output
username = output.decode().split(" ")[1]

# Return the username
return username

# Example usage
username = steal\_data("john\_doe")
print(username)
